        df_base[f"{col} match"] = 0
    df_bank["total matches"] = 0
    df_base["available"] = True ##Serie utilizada para saber si la transacción ha sido o no utilizada
    n = len(base_cols)
    
    for idx_bank in df_bank.index: ##por cada transacción
